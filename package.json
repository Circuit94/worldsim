{
  "name": "worldsim",
  "version": "0.2.0",
  "description": "AI World Simulation Engine — Generate interactive worlds with memory-driven agents, causal events, and emergent narratives using LLMs. Supports headless SDK mode for enterprise integration.",
  "type": "module",
  "main": "./src/engine/index.ts",
  "exports": {
    ".": "./src/engine/index.ts",
    "./engine": "./src/engine/index.ts"
  },
  "scripts": {
    "dev": "vite",
    "build": "tsc && vite build",
    "preview": "vite preview",
    "test": "vitest run",
    "test:watch": "vitest",
    "demo:headless": "npx tsx examples/headless-demo.ts"
  },
  "keywords": [
    "ai",
    "simulation",
    "generative-agents",
    "llm",
    "world-engine",
    "headless",
    "sdk",
    "behavioral-simulation",
    "agent-testing",
    "training-platform"
  ],
  "author": "Circuit94",
  "license": "MIT",
  "dependencies": {
    "@google/generative-ai": "^0.24.1",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "zustand": "^5.0.0"
  },
  "devDependencies": {
    "@tailwindcss/vite": "^4.0.0",
    "@types/react": "^19.0.0",
    "@types/react-dom": "^19.0.0",
    "@vitejs/plugin-react": "^4.0.0",
    "autoprefixer": "^10.4.0",
    "tailwindcss": "^4.0.0",
    "tsx": "^4.0.0",
    "typescript": "^5.6.0",
    "vite": "^6.0.0",
    "vitest": "^4.1.7"
  }
}
